# ===== 服务配置 =====
NODE_ENV=development
PORT=3000
API_PREFIX=/api

# ===== 数据库配置 =====
DB_HOST=localhost
DB_PORT=3306
DB_NAME=paibanbao
DB_USER=root
DB_PASSWORD=your_password

# ===== Redis配置 =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ===== JWT配置 =====
JWT_SECRET=your_jwt_secret_key_change_this
JWT_EXPIRES_IN=7d

# ===== 微信小程序配置 =====
WX_APPID=your_wx_appid
WX_SECRET=your_wx_secret

# ===== 对象存储配置（阿里云OSS）=====
OSS_REGION=oss-cn-hangzhou
OSS_ACCESS_KEY_ID=your_access_key_id
OSS_ACCESS_KEY_SECRET=your_access_key_secret
OSS_BUCKET=paibanbao-images
OSS_CDN_DOMAIN=https://cdn.paibanbao.com

# ===== AI Worker配置 =====
AI_WORKER_URL=http://localhost:8000
AI_WORKER_TIMEOUT=60000

# ===== 微信支付配置 =====
WX_PAY_MCH_ID=your_mch_id
WX_PAY_KEY=your_pay_key
WX_PAY_NOTIFY_URL=https://api.paibanbao.com/api/payment/notify

# ===== 限流配置 =====
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30
