<!--pages/mine/mine.wxml - 个人中心-->
<view class="container">
  <!-- 用户卡片 -->
  <view class="user-card">
    <!-- 已登录 -->
    <view class="user-info" wx:if="{{isLogin}}">
      <image class="avatar" src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" />
      <view class="user-detail">
        <text class="nickname">{{userInfo.nickName || '用户'}}</text>
        <text class="user-id">ID: PBB{{totalUsed + 10000}}</text>
      </view>
    </view>
    
    <!-- 未登录 -->
    <view class="user-info" wx:else>
      <image class="avatar" src="/images/default-avatar.png" />
      <view class="user-detail">
        <view class="login-btn" bindtap="onLogin">点击登录</view>
      </view>
    </view>

    <!-- 额度信息 -->
    <view class="credits-card">
      <view class="credits-item">
        <text class="credits-value">{{remainingCredits}}</text>
        <text class="credits-label">剩余次数</text>
      </view>
      <view class="credits-item">
        <text class="credits-value">{{totalUsed}}</text>
        <text class="credits-label">已使用</text>
      </view>
      <view class="credits-item">
        <text class="credits-value">{{historyCount}}</text>
        <text class="credits-label">换装记录</text>
      </view>
    </view>
  </view>

  <!-- 充值按钮 -->
  <view class="recharge-section">
    <button class="recharge-btn" bindtap="goRecharge">充值换装次数</button>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <view class="menu-item" bindtap="goRecharge">
      <text class="menu-icon">💎</text>
      <text class="menu-text">购买套餐</text>
      <text class="menu-badge">优惠</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="contactService">
      <text class="menu-icon">💬</text>
      <text class="menu-text">联系客服</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goHelp">
      <text class="menu-icon">📖</text>
      <text class="menu-text">使用帮助</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-item" bindtap="goAbout">
      <text class="menu-icon">ℹ️</text>
      <text class="menu-text">关于拍版宝</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="clearCache">
      <text class="menu-icon">🗑️</text>
      <text class="menu-text">清除缓存</text>
      <text class="menu-arrow">›</text>
    </view>
    <button class="menu-item" open-type="share" style="background: none; border: none; text-align: left; padding: 32rpx 30rpx; line-height: 1.6; margin: 0;">
      <text class="menu-icon">📤</text>
      <text class="menu-text">推荐给朋友</text>
      <text class="menu-arrow">›</text>
    </button>
  </view>

  <!-- 版本信息 -->
  <view class="version-info">
    <text>拍版宝 v1.0.0</text>
  </view>
</view>
