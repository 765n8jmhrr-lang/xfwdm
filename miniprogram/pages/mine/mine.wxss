/* 个人中心页样式 */
.user-card {
  background: linear-gradient(135deg, #4A90D9, #357ABD);
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  color: #fff;
}

.user-info {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.avatar {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.6);
  margin-right: 24rpx;
}

.user-detail {
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
}

.user-id {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 8rpx;
}

.login-btn {
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  border-radius: 30rpx;
  padding: 16rpx 40rpx;
  font-size: 28rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
  text-align: center;
  display: inline-block;
}

/* 额度信息 */
.credits-card {
  display: flex;
  justify-content: space-around;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  padding: 24rpx;
}

.credits-item {
  text-align: center;
}

.credits-value {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
}

.credits-label {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 6rpx;
}

/* 菜单列表 */
.menu-section {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.menu-arrow {
  font-size: 28rpx;
  color: #ccc;
}

.menu-badge {
  background: #E74C3C;
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
  margin-right: 16rpx;
}

/* 充值按钮 */
.recharge-section {
  padding: 20rpx 0;
  text-align: center;
}

.recharge-btn {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  font-size: 32rpx;
  background: linear-gradient(135deg, #F2994A, #F2C94C);
  color: #fff;
  border-radius: 50rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(242, 153, 74, 0.3);
}

/* 版本信息 */
.version-info {
  text-align: center;
  padding: 40rpx;
  font-size: 22rpx;
  color: #ccc;
}
