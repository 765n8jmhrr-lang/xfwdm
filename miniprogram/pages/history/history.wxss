/* 历史记录页样式 */
.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.clear-btn {
  font-size: 26rpx;
  color: #E74C3C;
  padding: 10rpx 20rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  opacity: 0.4;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #bbb;
}

/* 列表 */
.history-list {
  margin-top: 10rpx;
}

.history-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  display: flex;
  align-items: center;
}

.item-images {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.item-thumb {
  width: 100rpx;
  height: 130rpx;
  border-radius: 8rpx;
  background: #f5f5f5;
}

.item-arrow {
  font-size: 24rpx;
  color: #4A90D9;
}

.item-info {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.item-time {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.item-status {
  font-size: 22rpx;
  color: #27AE60;
  background: #E8F8F0;
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
  display: inline-block;
}

.item-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  flex-shrink: 0;
}

.action-view {
  font-size: 24rpx;
  color: #4A90D9;
  background: #EBF3FD;
  padding: 10rpx 20rpx;
  border-radius: 8rpx;
  text-align: center;
}

.action-delete {
  font-size: 24rpx;
  color: #E74C3C;
  background: #FDE8E8;
  padding: 10rpx 20rpx;
  border-radius: 8rpx;
  text-align: center;
}
