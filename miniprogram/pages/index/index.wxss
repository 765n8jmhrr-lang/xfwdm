/* 首页样式 */
.header {
  text-align: center;
  padding: 20rpx 0 40rpx;
}

.header .title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 10rpx;
}

.header .subtitle {
  display: block;
  font-size: 26rpx;
  color: #888;
}

/* 上传区域 */
.upload-section {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title .icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.section-title .label {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.section-title .tip {
  font-size: 22rpx;
  color: #999;
  margin-left: 16rpx;
}

.upload-area {
  width: 100%;
  min-height: 360rpx;
  border: 3rpx dashed #ccc;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  position: relative;
  overflow: hidden;
  background: #FAFBFC;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
}

.upload-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.6;
}

.upload-text {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.upload-hint {
  font-size: 22rpx;
  color: #aaa;
}

.preview-image {
  width: 100%;
  height: 400rpx;
}

.re-upload-btn {
  position: absolute;
  bottom: 16rpx;
  right: 16rpx;
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  font-size: 22rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

/* 预设模特 */
.preset-models {
  margin-top: 24rpx;
}

.preset-title {
  font-size: 24rpx;
  color: #888;
  margin-bottom: 16rpx;
  display: block;
}

.preset-scroll {
  white-space: nowrap;
}

.preset-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  margin-right: 24rpx;
}

.preset-avatar {
  width: 100rpx;
  height: 130rpx;
  border-radius: 12rpx;
  border: 2rpx solid #eee;
}

.preset-name {
  font-size: 20rpx;
  color: #666;
  margin-top: 8rpx;
}

/* 换装类型 */
.category-section {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.category-options {
  display: flex;
  gap: 20rpx;
}

.category-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 12rpx;
  background: #F5F7FA;
  font-size: 28rpx;
  color: #666;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.category-item.active {
  background: #EBF3FD;
  color: #4A90D9;
  border-color: #4A90D9;
  font-weight: 600;
}

/* 操作区域 */
.action-area {
  padding: 30rpx 0;
  text-align: center;
}

.start-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 34rpx;
  font-weight: 600;
}

.start-btn.disabled {
  opacity: 0.5;
  background: linear-gradient(135deg, #aaa, #999);
  box-shadow: none;
}

.credits-info {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #999;
}

/* 加载动画 */
.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #f0f0f0;
  border-top-color: #4A90D9;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin: 0 auto 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-tip {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

.progress-bar {
  width: 300rpx;
  height: 8rpx;
  background: #f0f0f0;
  border-radius: 4rpx;
  margin-top: 24rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #4A90D9, #67B8F7);
  border-radius: 4rpx;
  transition: width 0.3s;
}
